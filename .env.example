# ─────────────────────────────────────────────────────────────────────────────
# langchain-middleware-stack — environment configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for any cell that uses a real LLM instead of MockLLM.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: pin the default model used by langchain-openai ChatOpenAI
# OPENAI_MODEL=gpt-4o

# Optional: organisation ID (only needed for shared org accounts)
# OPENAI_ORG_ID=org-...

# ── LangSmith (LangChain tracing) ─────────────────────────────────────────────
# Enables full trace visibility for every LLM call, chain, and agent run.
# Sign up / get your key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...

# Project name shown in the LangSmith UI (defaults to "default")
LANGCHAIN_PROJECT=langchain-middleware-stack

# Optional: self-hosted LangSmith endpoint
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── LangChain general ─────────────────────────────────────────────────────────
# Verbose mode — logs every chain step to stdout (useful while prototyping)
# LANGCHAIN_VERBOSE=true
